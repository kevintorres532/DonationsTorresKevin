@page "/donate"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using DonationsTorresKevin.Data
@using DonationsTorresKevin.Services
@using System.Security.Claims

@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext DbContext
@inject StripeCheckoutService StripeService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Make a Donation</PageTitle>

<div class="card shadow-sm mt-4 p-4" style="max-width:400px; margin:auto;">

    <EditForm Model="donationModel"
              OnValidSubmit="ProcessDonation"
              FormName="DonationForm">

        <DataAnnotationsValidator />

        <h2 class="card-title fw-bold text-dark mb-2">
            Apoya nuestra causa
        </h2>

        <div class="alert alert-success text-center mb-4" role="alert">
            <h5 class="alert-heading fw-bold">
                ¡Gracias por su donación!
            </h5>

            <p class="mb-0">
                Su apoyo hace posible nuestra misión.
            </p>
        </div>

        <p class="card-text text-muted text-center mb-4">
            Seleccione el fondo y la cantidad que desea donar.
        </p>

        <div class="mb-3">

            <label class="form-label fw-semibold">
                Seleccionar Fondo
            </label>

            <select class="form-select">

                <option selected>
                    Fondo General
                </option>

                <option value="1">
                    Educación
                </option>

                <option value="2">
                    Salud
                </option>

                <option value="3">
                    Ayuda Humanitaria
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Monto a donar (USD)
            </label>

            <div class="input-group">

                <span class="input-group-text">
                    $
                </span>

                <InputNumber @bind-Value="donationModel.Amount"
                             class="form-control"
                             min="1"
                             step="0.50" />

            </div>

            <ValidationMessage For="@(() => donationModel.Amount)"
                               class="text-danger" />

        </div>

        <button type="submit"
                class="btn btn-success w-100"
                disabled="@isProcessing">

            @if (isProcessing)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Procesando...</span>
            }
            else
            {
                <span>Donar vía Stripe</span>
            }

        </button>

    </EditForm>

</div>

@code {

    private DonationInputModel donationModel = new()
    {
        Amount = 10.00m
    };

    private bool isProcessing = false;

    private class DonationInputModel
    {
        [Required]
        [Range(
            1.00,
            10000.00,
            ErrorMessage = "El monto debe estar entre $1 y $10,000"
        )]

        public decimal Amount { get; set; }
    }

    private async Task ProcessDonation()
    {
        isProcessing = true;

        StateHasChanged();

        var authState =
            await AuthStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        var userId =
            user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(userId))
        {
            isProcessing = false;
            return;
        }

        var newDonation = new Donation
        {
            UserId = userId,
            Amount = donationModel.Amount,
            Currency = "usd",
            Status = "Pending",
            CreatedAt = DateTime.UtcNow
        };

        DbContext.Donations.Add(newDonation);

        await DbContext.SaveChangesAsync();

        var baseUrl = Navigation.BaseUri;

        var successUrl =
            $"{baseUrl}donate/success";

        var cancelUrl =
            $"{baseUrl}donate/cancel";

        var checkoutUrl =
            await StripeService.CreateCheckoutSessionAsync(
                newDonation.Amount,
                newDonation.Currency,
                newDonation.Id.ToString(),
                successUrl,
                cancelUrl
            );

        Navigation.NavigateTo(
            checkoutUrl,
            forceLoad: true
        );

        isProcessing = false;
    }

}